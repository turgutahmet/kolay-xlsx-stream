# Files & directories excluded from Composer dist tarballs.
# Keeps `composer require kolay/xlsx-stream` install lean.

# Development & meta directories
/.github                       export-ignore
/tests                         export-ignore
/examples                      export-ignore

# Dotfiles
/.gitattributes                export-ignore
/.gitignore                    export-ignore
/.editorconfig                 export-ignore
/.env.example                  export-ignore

# Tooling configs (not needed at runtime)
/phpunit.xml.dist              export-ignore
/phpstan.neon                  export-ignore
/pint.json                     export-ignore

# Maintainer/dev scripts
/benchmark-comprehensive.php   export-ignore

# Maintainer-facing docs (GitHub renders these; vendor/ user doesn't need them)
/CHANGELOG.md                  export-ignore
/UPGRADE.md                    export-ignore
/ROADMAP.md                    export-ignore
/CONTRIBUTING.md               export-ignore
/CODE_OF_CONDUCT.md            export-ignore
/SECURITY.md                   export-ignore

# README.md and LICENSE.md intentionally NOT export-ignored —
# they are user-facing.

# Normalize line endings for source files
*.php                          text eol=lf
*.json                         text eol=lf
*.md                           text eol=lf
*.yml                          text eol=lf
*.yaml                         text eol=lf
